{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document containing authentication, membership levels, and wallet balances",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique username" },
        "fullName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "description": "User's registered email" },
        "phone": { "type": "string", "description": "User's phone number" },
        "avatarUrl": { "type": "string", "description": "URL to user's profile avatar" },
        "userLevel": { "type": "string", "description": "FREE, REGULAR, PREMIUM or ELITE membership status" },
        "walletBalance": { "type": "number", "description": "User's wallet balance in BDT" },
        "createdAt": { "type": "string", "description": "Account registration timestamp" }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "Companion booking requests by customers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "modelName": { "type": "string" },
        "modelTag": { "type": "string" },
        "location": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "duration": { "type": "string" },
        "image": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "secretCode": { "type": "string" },
        "cost": { "type": "number" },
        "firstTimeBooking": { "type": "boolean" },
        "userPhoto": { "type": "string" },
        "nidFront": { "type": "string" },
        "nidBack": { "type": "string" },
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "clientEmail": { "type": "string" }
      }
    },
    "Companion": {
      "title": "Companion",
      "description": "Roster of available companion profiles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tag": { "type": "string" },
        "badge": { "type": "string" },
        "image": { "type": "string" },
        "age": { "type": "number" },
        "height": { "type": "string" },
        "bodyColor": { "type": "string" },
        "weight": { "type": "string" },
        "bust": { "type": "string" },
        "waist": { "type": "string" },
        "hip": { "type": "string" },
        "languages": { "type": "array" },
        "specialty": { "type": "string" },
        "rate": { "type": "number" },
        "rateReal": { "type": "number" },
        "rateCam": { "type": "number" },
        "rateMakeOut": { "type": "number" },
        "rateLiveTogether": { "type": "number" },
        "city": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "spermCount": { "type": "string" },
        "nidFront": { "type": "string" },
        "nidBack": { "type": "string" },
        "selfie": { "type": "string" },
        "telegram": { "type": "string" }
      }
    },
    "Location": {
      "title": "Location",
      "description": "Hotel locations and rates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "star": { "type": "string" },
        "location": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "mapEmbedUrl": { "type": "string" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Reviews on companions left by clients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookingId": { "type": "string" },
        "companionName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "reviewerName": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment transactions submitted by users for verification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "tierName": { "type": "string" },
        "price": { "type": "string" },
        "method": { "type": "string" },
        "trxId": { "type": "string" },
        "status": { "type": "string" },
        "date": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{username}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Booking requests and outcomes"
    },
    "companions/{companionId}": {
      "schema": "Companion",
      "description": "Available companions list"
    },
    "locations/{locationId}": {
      "schema": "Location",
      "description": "Hotel locations list"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Companions reviews from users"
    },
    "payments/{paymentId}": {
      "schema": "Payment",
      "description": "Transaction verifications"
    }
  }
}
