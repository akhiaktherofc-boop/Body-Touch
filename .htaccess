DirectoryIndex index.html

# Hostinger SPA Routing - Serves React Router SPA from public_html root
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Do not do anything for existing files, directories, or symlinks
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback all other requests (like /about, /dashboard, etc.) to index.html for client-side React routing
  RewriteRule ^ index.html [L]
</IfModule>

